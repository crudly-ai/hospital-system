        if (($request->wantsJson() || $request->ajax()) && !$request->header('X-Inertia')) {
            ${{variable_name}} = {{model_name}}::select('{{table_name}}.*'){{relationship_with}};
            
            // Apply ownership filter
            if (auth()->user()->can('manage_all_{{permission_name}}')) {
                // User can see all {{plural_name}}
            } elseif (auth()->user()->can('manage_own_{{permission_name}}')) {
                ${{variable_name}}->where('created_by', auth()->id());
            }
            
{{filters}}
            
            return DataTables::of(${{variable_name}})
