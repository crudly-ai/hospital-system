    public function show({{model_name}} ${{singular_name}})
    {
        if (!auth()->user()->can('view_{{permission_name}}')) {
            abort(403, 'You do not have permission to view this {{singular_name}}.');
        }

        ${{singular_name}}->load([{{relationship_load_array}}]);
        return response()->json(${{singular_name}});
