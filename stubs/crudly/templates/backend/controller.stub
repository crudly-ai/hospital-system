    public function store(Request $request)
    {
        if (!auth()->user()->can('create_{{permission_name}}')) {
            abort(403, 'You do not have permission to create {{plural_name}}.');
        }
        
        $request->validate([
{{validation_rules}}
        ]);

        {{model_name}}::create(array_merge($request->all(), ['created_by' => auth()->id()]));

        return redirect()->back()->with('success', '{{model_name}} created successfully.');
    }

    public function update(Request $request, {{model_name}} ${{singular_name}})
    {
        if (!auth()->user()->can('edit_{{permission_name}}')) {
            abort(403, 'You do not have permission to edit {{plural_name}}.');
        }
        
        // Check ownership for manage_own permission
        if (!auth()->user()->can('manage_all_{{permission_name}}') && 
            auth()->user()->can('manage_own_{{permission_name}}') && 
            ${{singular_name}}->created_by !== auth()->id()) {
            abort(403, 'You can only edit {{plural_name}} you created.');
        }
        
        $request->validate([
{{update_validation_rules}}
        ]);

        ${{singular_name}}->update($request->all());

        return redirect()->back()->with('success', '{{model_name}} updated successfully.');
    }

    public function destroy({{model_name}} ${{singular_name}})
    {
        if (!auth()->user()->can('delete_{{permission_name}}')) {
            abort(403, 'You do not have permission to delete {{plural_name}}.');
        }
        
        // Check ownership for manage_own permission
        if (!auth()->user()->can('manage_all_{{permission_name}}') && 
            auth()->user()->can('manage_own_{{permission_name}}') && 
            ${{singular_name}}->created_by !== auth()->id()) {
            abort(403, 'You can only delete {{plural_name}} you created.');
        }
        
        ${{singular_name}}->delete();

        return redirect()->back()->with('success', '{{model_name}} deleted successfully.');
    }
